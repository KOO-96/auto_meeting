APP_ENV=local
APP_NAME=Company Brain Lite
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/company_brain
REDIS_URL=redis://redis:6379/0

# REQUIRED: generate a strong secret before running, e.g. `openssl rand -hex 32`.
# The app refuses to start with an empty or placeholder value.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

UPLOAD_DIR=/app/storage/uploads
EXPORT_DIR=/app/storage/exports
MAX_UPLOAD_SIZE_MB=1024

RQ_QUEUE_NAME=meeting-processing

AI_WORKER_ENABLED=true
AI_MODEL_BASE_URL=http://localhost:8001/v1
AI_MODEL_NAME=test-9b-llm
AI_MODEL_TIMEOUT_SECONDS=120
AI_MODEL_MAX_TOKENS=2048
AI_MODEL_TEMPERATURE=0

# Speech-to-text (optional). Leave STT_BASE_URL empty to use the mock transcript.
# Point at an OpenAI-compatible /audio/transcriptions endpoint (e.g. Whisper).
STT_BASE_URL=
STT_MODEL=whisper-1
# STT_LANGUAGE=ko

# Screen-recording frame sampling for VLM analysis (requires ffmpeg on PATH).
SCREEN_FRAME_SAMPLING_ENABLED=true
SCREEN_FRAME_INTERVAL_SECONDS=60
SCREEN_FRAME_MAX=5

# Structured JSON logs (recommended outside local dev).
JSON_LOGS=false

# Login rate limiting (fixed window).
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
