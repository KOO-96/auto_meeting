    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-log": "^5.4.4",
    "lucide-react": "^1.18.0",
